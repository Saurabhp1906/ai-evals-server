# Database
DATABASE_URL=postgresql://user:password@host:5432/ai_evals

# Supabase Auth — get these from your Supabase project settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Fernet key for encrypting API keys at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# LLM provider keys (used as fallback; users add their own via Connections)
ANTHROPIC_API_KEY=sk-ant-...

# Resend — for sending invite emails
# Get your API key at https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM=EvalPeak <noreply@yourdomain.com>
APP_URL=https://yourdomain.com
